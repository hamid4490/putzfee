# .env.example — copy to .env and fill in values

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/putz
JWT_SECRET=change-me-secret
PASSWORD_PEPPER=change-me-pepper

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

ADMIN_KEY=CHANGE_ME_ADMIN
ADMIN_PHONES=09123456789,09987654321

LOGIN_WINDOW_SECONDS=600
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_SECONDS=1800

ALLOW_ORIGINS=*

# FCM v1 (recommended)
FCM_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS_JSON_B64=base64_encoded_service_account_json

# FCM legacy (fallback)
FCM_SERVER_KEY=

# ntfy (alternative to FCM)
PUSH_BACKEND=fcm
NTFY_BASE_URL=https://ntfy.sh
NTFY_AUTH=

# Media
MEDIA_DIR=media
MEDIA_URL_PREFIX=/media
PUBLIC_BASE_URL=https://yourdomain.com
MAX_IMAGE_BYTES=5000000
MEDIA_TARGET_WIDTH=1200
MEDIA_TARGET_HEIGHT=1200
MEDIA_SAVE_FORMAT=JPEG
MEDIA_JPEG_QUALITY=82
MEDIA_WEBP_QUALITY=82

ENABLE_SCHEMA_CREATE=true
