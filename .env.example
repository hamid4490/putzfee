# PUTZFEE Server — example environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# -------------------------------------------------------------------
# Database
# -------------------------------------------------------------------
# Async URL for `databases`/asyncpg, e.g.:
#   postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql://putzfee_tjgq_user:KFEGnJHks5EfcgLFHnQB3Z5L69fSWcty@dpg-d6sgt4nfte5s73f7t6b0-a/putzfee_tjgq

# -------------------------------------------------------------------
# Security / Auth
# -------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=64dc57d80e3d07b9bbb9719ca1688ea7
# Extra pepper mixed with password before bcrypt. Generate same way.
PASSWORD_PEPPER=4f5f6724557a301ca3a48d3f1a9f08ae
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12

# First-time admin bootstrap. Comma-separated phones that auto-receive
# `is_admin=true` on registration. AFTER first admin is created, leave empty.
ADMIN_PHONES=09191670037

# Login brute-force protection
LOGIN_WINDOW_SECONDS=300
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_SECONDS=900

# Comma-separated allowed CORS origins, e.g.:
#   https://app.putzfee.de,https://admin.putzfee.de
# Use "*" ONLY for local development.
ALLOW_ORIGINS=*

# -------------------------------------------------------------------
# Timezone & scheduling
# -------------------------------------------------------------------
# IANA timezone name for the business. All work hours / slots are
# computed in this timezone. Stored timestamps remain UTC.
SERVER_TIMEZONE=Europe/Berlin
WORK_START_HOUR=8
WORK_END_HOUR=20
SLOT_DURATION_HOURS=1
# Max simultaneous proposed slots a user may submit per request.
MAX_SLOTS_PER_REQUEST=2

# -------------------------------------------------------------------
# Push notifications (FCM v1)
# -------------------------------------------------------------------
FCM_PROJECT_ID=putzfee
# Base64-encoded service-account JSON. Generate with:
#   base64 -w0 service-account.json
GOOGLE_APPLICATION_CREDENTIALS_JSON_


# -------------------------------------------------------------------
# Media / uploads
# -------------------------------------------------------------------
MEDIA_DIR=./media
MEDIA_URL_PREFIX=/media
PUBLIC_BASE_URL=http://localhost:8000
MAX_IMAGE_BYTES=5242880
MEDIA_TARGET_WIDTH=1280
MEDIA_TARGET_HEIGHT=1280
MEDIA_SAVE_FORMAT=webp
MEDIA_JPEG_QUALITY=85
MEDIA_WEBP_QUALITY=80

# -------------------------------------------------------------------
# AI assistant
# -------------------------------------------------------------------
# Provider: gemini (recommended) | openai
AI_PROVIDER=gemini
AI_API_KEY=
# gemini: e.g. gemini-1.5-flash
# openai: e.g. gpt-4o-mini
AI_MODEL=gemini-1.5-flash
AI_MAX_TOKENS=512
AI_TEMPERATURE=0.4
# Per-user requests per minute
AI_RATE_PER_MINUTE=8
# Per-user requests per day
AI_RATE_PER_DAY=50

# -------------------------------------------------------------------
# Operational flags
# -------------------------------------------------------------------
# DEV ONLY. In production keep this 0 and rely on Alembic.
ENABLE_SCHEMA_CREATE=0
# Environment name (development | staging | production)
APP_ENV=development
